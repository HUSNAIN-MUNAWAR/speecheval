SPEECHEVAL_ENV=development
SPEECHEVAL_API_PREFIX=/api/v1
SPEECHEVAL_DATABASE_URL=sqlite:///./.data/speecheval.db
SPEECHEVAL_CORS_ORIGINS=http://localhost:3000
SPEECHEVAL_ARTIFACT_ROOT=./.artifacts
SPEECHEVAL_LOG_LEVEL=INFO
SPEECHEVAL_DEMO_MODE=true
SPEECHEVAL_MAX_UPLOAD_SIZE_MB=100
SPEECHEVAL_MAX_AUDIO_DURATION_SECONDS=300
SPEECHEVAL_QUEUE_MODE=inline
SPEECHEVAL_WORKER_POLL_SECONDS=0.6
SPEECHEVAL_ENABLE_PROMETHEUS=true
POSTGRES_DB=speecheval
POSTGRES_USER=speecheval
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-please
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
